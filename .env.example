# Copy this file to ".env" and fill in your keys. The app loads it on startup.
# Anything you leave blank can still be typed into the web UI instead.

# --- API keys (required, unless entered in the UI) ---
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=

# --- Optional: override the default models shown in the UI ---
# CLAUDE_MODEL=claude-sonnet-4-6
# CHATGPT_MODEL=gpt-4o

# --- Login (leave unset for local dev = no auth). Set ONE to enable. ---
# Single shared password (any username accepted):
# APP_PASSWORD=change-me
# Or named users (comma-separated user:password pairs):
# APP_USERS=ada:hunter2,grace:s3cret
# Secret that signs the login cookie (set a long random value in production):
# SECRET_KEY=generate-a-long-random-string
# Set to 1 when served over HTTPS (production) so the cookie is HTTPS-only:
# COOKIE_SECURE=0

# --- Deployment ---
# Managed-keys mode: 1 = always use the keys above and hide the UI key fields
# (public deploys); 0 = let each visitor enter their own key. Default 0.
# MANAGED_KEYS=0
# Where to store the history DB (defaults to ./debates.db locally;
# on Render with a disk, set to /var/data/debates.db):
# DEBATE_DB=/var/data/debates.db
